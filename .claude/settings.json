{
  "permissions": {
    "allow": [
      "Read(.claude/docs/**)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env/**)",
      "Bash(cat *.env*)",
      "Bash(cat *.env)",
      "Bash(cat .env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)"
    ]
  }
}