# #
# Application

APP_ENV=develop

# #
# Infrasturucture

# server
DEVELOP_API_HOST=0.0.0.0
DEVELOP_API_PORT=28200
DEVELOP_API_CONTAINER_PORT=28200

# mcp
DEVELOP_MCP_PORT=28199
DEVELOP_MCP_CONTAINER_PORT=28199

# dev DB
DEVELOP_POSTGRES_USER=develop_user
DEVELOP_POSTGRES_PASSWORD=develop_password
DEVELOP_POSTGRES_HOST=database
DEVELOP_POSTGRES_PORT=25634
DEVELOP_POSTGRES_CONTAINER_PORT=5432
DEVELOP_POSTGRES_DB=develop_db

# test DB
TEST_POSTGRES_USER=test_user
TEST_POSTGRES_PASSWORD=test_password
TEST_POSTGRES_HOST=database-test
TEST_POSTGRES_PORT=25633
TEST_POSTGRES_CONTAINER_PORT=5432
TEST_POSTGRES_DB=test_db

# #
# Feature

# crypto
DEVELOP_ARGON2_TIME_COST=3
DEVELOP_ARGON2_MEMORY_COST=65536
DEVELOP_ARGON2_PARALLELISM=4
DEVELOP_SESSION_TTL_SEC=900